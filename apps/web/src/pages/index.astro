---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Verokodo">
	<main id="oracle-experience" class="oracle-experience" data-state="intro">
		<canvas id="intro-smoke-canvas" class="intro-smoke-canvas" aria-hidden="true"></canvas>
		<section id="intro-screen" class="intro-screen">
			<div class="intro-content">
				<button id="intro-enter-button" class="intro-enter-button" type="button" aria-label="Enter Verokodo">
					<span id="intro-title">Verokodo</span>
				</button>
				<p id="intro-instruction" class="intro-instruction">Click title to start</p>
			</div>
		</section>

		<div id="crystal-canvas" class="crystal-canvas" aria-hidden="true"></div>
		<div class="orb-vignette" aria-hidden="true"></div>

		<section class="experience-frame">
			<header class="brand-row">
				<h1 id="home-title" class="brand-title">Verokodo</h1>
			</header>

			<section class="orb-stage">
				<div class="orb-shell">
					<div class="orb-content">
						<p id="screen-announce" class="sr-only" aria-live="polite"></p>
						<p id="home-note" class="orb-note">Use your GitHub username to get a glimpse of your dev future.</p>
						<form id="oracle-form" class="orb-form" aria-label="Start oracle reading">
							<label id="username-label" for="username" class="sr-only">GitHub Username</label>
							<div class="orb-input-shell">
								<input
									id="username"
									name="username"
									placeholder="octocat"
									autocomplete="username"
									list="recent-usernames"
									aria-describedby="username-hint username-shortcut"
									required
									maxlength="39"
									pattern="[A-Za-z0-9](?:[A-Za-z0-9]|-){0,37}"
								/>
								<button id="start-button" class="start-reading" type="submit">Go</button>
							</div>
							<datalist id="recent-usernames"></datalist>
						</form>

						<div class="form-meta">
							<p id="username-shortcut" class="status-text">Press <kbd>/</kbd> to focus</p>
							<p id="username-hint" class="status-text">Only public GitHub usernames are supported.</p>
							<div id="recent-usernames-panel" class="recent-usernames-panel" hidden>
								<div class="recent-usernames-header">
									<p id="recent-usernames-title" class="status-text recent-usernames-title">Recent usernames</p>
									<button id="clear-recent" class="ghost-inline subtle-clear" type="button" hidden>Clear recent</button>
								</div>
								<div id="recent-usernames-list" class="recent-usernames-list"></div>
							</div>
						</div>

						<section id="loading-panel" class="oracle-panel loading-panel" aria-live="polite" aria-busy="true">
							<p id="loading-label" class="status-eyebrow">Reading in progress</p>
							<p id="loading-status" class="status-text">Collecting profile signals...</p>
							<div class="loading-progress" aria-hidden="true">
								<span id="loading-progress-bar"></span>
							</div>
							<p id="loading-meta" class="loading-meta">Step 1 of 3 - 0.0s</p>
							<div class="action-row compact-actions">
								<button id="cancel-reading" type="button">Cancel</button>
							</div>
						</section>

						<section id="error-panel" class="oracle-panel error-panel" aria-live="polite">
							<p id="error-text" class="error-banner"></p>
							<div class="action-row compact-actions">
								<button id="copy-error" type="button">Copy Error</button>
								<button id="retry-reading" type="button">Try Again</button>
							</div>
						</section>

						<section id="result-panel" class="oracle-panel result-panel" aria-live="polite">
							<button id="go-back" class="go-back-button" type="button">Go back</button>
							<div class="result-scroll">
								<p id="result-eyebrow" class="status-eyebrow">Reading complete</p>
								<h2 id="result-title">Reading for @username</h2>
								<p id="result-summary" class="lead"></p>

								<article id="result-prophecy" class="prophecy-card"></article>

								<article class="prophecy-card">
									<h3 id="result-five-year-label" class="forecast-title">5-year outlook</h3>
									<p id="result-five-year"></p>
								</article>

								<article class="prophecy-card">
									<h3 id="result-ten-year-label" class="forecast-title">10-year outlook</h3>
									<p id="result-ten-year"></p>
								</article>

							<div id="signal-grid" class="signal-grid"></div>

							<div class="action-row result-actions">
								<button id="share-image" type="button">Share Reading Image</button>
								<button id="share-x" type="button">Share on X</button>
							</div>
							<p id="result-meta" class="status-text result-meta"></p>
						</div>
						</section>
					</div>
				</div>
			</section>

			<footer class="experience-footer">
				<p class="footer-line">
					<span id="footer-copyright">© 2026 Thayrov. Released under the</span>
					<span id="footer-license-link">MIT License</span>.
				</p>
				<p id="footer-about" class="footer-line">About this website: built with Astro, TypeScript, Three.js, Hono, Bun, Zod, Vercel AI SDK, Docker Compose, and NGINX.</p>
				<p class="footer-line"><span id="footer-visit-prefix">Visit me at </span><a class="footer-link" href="https://thayrov.com" target="_blank" rel="noopener noreferrer">thayrov.com</a></p>
			</footer>
		</section>
	</main>
</Layout>

<script src="../scripts/oracle-experience.ts"></script>
